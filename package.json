{
    "name": "@iletai/nzb",
    "version": "1.10.1",
    "description": "NZB — a personal AI assistant for developers, built on the GitHub Copilot SDK",
    "bin": {
        "nzb": "dist/cli.js"
    },
    "publishConfig": {
        "access": "public"
    },
    "files": [
        "dist/**/*.js",
        "scripts/fix-esm-imports.cjs",
        "skills/",
        "README.md"
    ],
    "scripts": {
        "build": "tsc",
        "test": "vitest run",
        "test:watch": "vitest",
        "postinstall": "node scripts/fix-esm-imports.cjs",
        "daemon": "tsx src/daemon.ts",
        "tui": "tsx src/tui/index.ts",
        "dev": "tsx --watch src/cli.ts start",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "prepublishOnly": "npm run build"
    },
    "engines": {
        "node": ">=18"
    },
    "keywords": [
        "copilot",
        "telegram",
        "orchestrator",
        "ai",
        "cli"
    ],
    "author": "iletai",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/iletai/AI-Agent-Assistant.git"
    },
    "homepage": "https://github.com/iletai/AI-Agent-Assistant#readme",
    "bugs": {
        "url": "https://github.com/iletai/AI-Agent-Assistant/issues"
    },
    "type": "module",
    "dependencies": {
        "@github/copilot-sdk": "^0.2.0",
        "@grammyjs/auto-retry": "^2.0.2",
        "@grammyjs/menu": "^1.3.1",
        "@grammyjs/runner": "^2.0.3",
        "@grammyjs/transformer-throttler": "^1.2.1",
        "better-sqlite3": "^12.6.2",
        "croner": "^10.0.1",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "grammy": "^1.40.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.13",
        "@types/express": "^5.0.6",
        "@types/node": "^25.3.0",
        "@vitest/coverage-v8": "^4.1.0",
        "prettier": "^3.8.1",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vitest": "^4.1.0"
    }
}
